generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// User roles enum
enum UserRole {
    ADMIN
    MANAGER
    DRIVER
    CLIENT
    SUBCONTRACTOR
}

// User model
model User {
    id        Int      @id @default(autoincrement())
    email     String
    password  String
    role      UserRole
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([email, role], name: "email_role_unique")
    @@index([email])
    @@map("users")
}
