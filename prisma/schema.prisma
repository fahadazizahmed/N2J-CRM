generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────

enum GstStatus {
  pending
  approved
  notApproved

  @@map("gst_status")
}

enum CreditTerms {
  net_7
  net_14
  net_30
  net_60
  cod

  @@map("credit_terms")
}

enum ClientStatus {
  pending
  active
  suspended

  @@map("client_status")
}

enum ContractType {
  client
  supplier
}


enum TipStatus {
  pending
  active
  suspended

  @@map("tip_status")
}

enum ContractStatus {
  draft
  active
  suspended
  expired
  cancelled

  @@map("contract_status")
}

enum ApprovalStatus {
  pendingReview
  approved
  conditionallyApproved
  rejected
  @@map("approval_status")
}

enum BillingType {
  perTonne
  perLoad
  hourly
  fixed
}

enum TollHandling {
  included
  passThrough
}

enum SequenceEntity {
  CLIENT
  CONTRACT
  INVOICE
  TIPPER
  VEHICLE
  JOB
}

// ─── Core Models ────

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id                Int              @id @default(autoincrement())
  name              String?
  email             String           @unique
  password_hash     String
  roles             Role[]
  active_role       String?
  status            Int              @default(1) // 0: inactive, 1: active
  last_login        DateTime?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  invite_token      String?
  audit_logs        AuditLog[]
  sessions          UserSession[]
  clients           Client[] // primary contact for clients
  driver            Driver?
  // ─── Contract Relations ───
  managed_contracts ClientContract[] @relation("ContractManager")
  created_contracts ClientContract[] @relation("ContractCreator")
  created_jobs      Job[]            @relation("JobCreator")

  @@map("users")
}

model UserSession {
  id         Int       @id @default(autoincrement())
  user_id    Int
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token      String    @db.Text
  ip_address String?
  user_agent String?
  login_at   DateTime  @default(now())
  logout_at  DateTime?
  status     Int       @default(1) // 1: Active, 0: Inactive
  expires_at DateTime?

  @@map("user_sessions")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actor_id    Int?
  actor       User?    @relation(fields: [actor_id], references: [id])
  action      String // CREATE, UPDATE, DELETE, INVITE_SENT, LOGIN, etc.
  entity_type String // User, Job, Invoice, Vehicle, etc.
  entity_id   Int? // ID of the entity affected
  metadata    Json? // Optional JSON data for extra details
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model FailedOperation {
  id             Int       @id @default(autoincrement())
  operation_type String // 'EMAIL' or 'AUDIT_LOG'
  entity_type    String // 'USER', 'ORDER', etc.
  entity_id      Int? // ID of the entity affected
  payload        Json // Store the data that failed (email details, audit log details)
  error_message  String?   @db.Text
  retry_count    Int       @default(0)
  status         String    @default("PENDING") // 'PENDING', 'RETRIED', 'RESOLVED', 'ABANDONED'
  created_at     DateTime  @default(now())
  last_retry_at  DateTime?
  resolved_at    DateTime?

  @@map("failed_operations")
}

// ─── Client ────

model Client {
  id          Int    @id @default(autoincrement())
  client_code String @unique
  // Primary contact user (the User row created for this client)
  user_id     Int    @unique // 1-to-1: each client has exactly one user account
  user        User   @relation(fields: [user_id], references: [id], onDelete: Restrict)

  client_name  String // mirrors User.name — the client's business / display name
  abn          String? @unique
  address      String?
  phone        String?
  country_code String? // e.g. "AU", "US" — used for phone validation

  // Financial settings
  gst_status   GstStatus   @default(pending)
  credit_terms CreditTerms @default(net_30)
  credit_score Int         @default(0)

  status     ClientStatus @default(pending)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  contracts ClientContract[]
  jobs      Job[]

  @@index([status])
  @@map("clients")
}

// ─── Tip Company ────

model TipCompany {
  id           Int     @id @default(autoincrement())
  client_code  String  @unique
  tip_name     String
  abn          String? @unique
  address      String?
  phone        String?
  country_code String?

  status TipStatus @default(pending)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("tip_companies")
}

// ─── Client Contract ────

model ClientContract {
  id Int @id @default(autoincrement())

  client_id Int?
  client    Client? @relation(fields: [client_id], references: [id])

  company_name String
  abn          String?
  address      String?
  phone        String?
  country_code String?

  contract_number String @unique
  contract_title  String?
  contract_type   ContractType @default(client)
  email           String?

  contract_contact_name  String?
  contract_contact_email String?
  contract_contact_phone String?

  start_date DateTime?
  end_date   DateTime?
  status     ContractStatus @default(draft)
  approval_status ApprovalStatus @default(pendingReview)
  approval_reason String?

  credit_terms_override CreditTerms?

  special_terms String?

  // ─── Internal Management ───
  contract_manager_id Int?
  contract_manager    User? @relation("ContractManager", fields: [contract_manager_id], references: [id], onDelete: SetNull)

  // ─── Audit Tracking ───
  created_by Int
  creator    User @relation("ContractCreator", fields: [created_by], references: [id], onDelete: Restrict)

  documents ClientContractDocument[]
  rates     ClientContractRate[]
  jobs      Job[] @relation("JobContract")
  tips      Job[] @relation("JobTip")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([client_id])
  @@index([status])
  @@index([abn])
}

model ClientContractDocument {
  id Int @id @default(autoincrement())

  // ─── Relation ───
  contract_id Int
  contract    ClientContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  // ─── Document Details ───
  document_path String
  file_name     String?

  created_at DateTime @default(now())

  @@index([contract_id])
  @@map("client_contract_documents")
}

model ClientContractRate {
  id Int @id @default(autoincrement())

  // ─── Relation ───
  contract_id Int
  contract    ClientContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  // ─── Billing Logic ───
  billing_type   BillingType
  material_type  String? // optional (future expansion)
  rate           Float
  minimum_charge Float?
  toll_handling  TollHandling @default(included)

  // ─── Version Control ───
  effective_from DateTime
  effective_to   DateTime?

  created_at DateTime @default(now())

  @@index([contract_id, effective_from])
  @@map("client_contract_rates")
}

model EntitySequence {
  id      Int            @id @default(autoincrement())
  entity  SequenceEntity
  year    Int
  last_no Int

  @@unique([entity, year], name: "entity_year")
}

// ─── Fleet / Vehicle Module ────

model Vehicle {
  id Int @id @default(autoincrement())

  vehicle_number      String?       @unique // auto-generated: NJA-VH-YYYY-XXX
  registration_number String        @unique
  model               String?
  make                String?
  make_year           Int?
  notes               String? // additional specifications or admin notes

  vehicle_type_id Int
  vehicle_type    VehicleType @relation(fields: [vehicle_type_id], references: [id])

  status           VehicleStatus   @default(active)
  vehicle_category VehicleCategory @default(inHouse)

  driver_id Int?
  driver    Driver? @relation("VehicleAssignedDriver", fields: [driver_id], references: [id], onDelete: SetNull)

  mileage           Int?
  last_service_date DateTime?
  service_mileage   Int?

  media VehicleMedia[]
  created_by Int? // admin who created vehicle

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
   job_assignments JobAssignment[] 

  @@index([vehicle_type_id])
  @@index([driver_id])
  @@map("vehicles")
}

model VehicleType {
  id Int @id @default(autoincrement())

  name        String  @unique
  description String?

  vehicles Vehicle[]

  created_at DateTime @default(now())

  @@map("vehicle_types")
}

enum VehicleStatus {
  active
  idle
  maintenance
  outOfService

  @@map("vehicle_status")
}

enum VehicleCategory {
  inHouse
  casual
  subcontractor

  @@map("vehicle_category")
}

enum VehicleDocumentType {
  registration
  insurance
  maintenance
  compliance
  photos
  other

  @@map("vehicle_document_type")
}

model VehicleMedia {
  id Int @id @default(autoincrement())

  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  vehicle_document_type VehicleDocumentType
  file_path             String
  file_name             String?
  file_type             String?
  is_active             Boolean   @default(true)
  expiry_date           DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vehicle_id])
  @@map("vehicle_media")
}


enum DriverStatus {
  active
  inactive
  suspended
  onLeave
  onBreak
  idle

  @@map("driver_status")
}

  enum DriverType {
  inHouse
  subcontractor
  casual

  @@map("driver_type")
}

enum DriverDocumentType {
  license
  medical
  certification
  training
  compliance
  identity
  insurance
  whiteCard
  other

  @@map("driver_document_type")
}

enum LicenseClass {
  C
  LR
  MR
  HR
  HC
  MC

  @@map("license_class")
}

model Driver {
  id Int @id @default(autoincrement())

  first_name String
  last_name  String

  email String?
  phone String?

  photo_path String? // driver profile photo

  // User account for the driver
  user_id Int?  @unique
  user    User? @relation(fields: [user_id], references: [id], onDelete: Restrict)

  driver_type DriverType
  status      DriverStatus @default(active)
  is_mobile_access Boolean      @default(false)

  // license information
  license_number String?
  license_class  LicenseClass?
  license_expiry DateTime?

  // GPS tracking for mobile app
  current_latitude     Float?
  current_longitude    Float?
  last_location_update DateTime?

  // relations
  documents DriverDocument[]
  rates     DriverRate[]
  job_assignments JobAssignment[] 

  // vehicles driven by this driver
  assigned_vehicles Vehicle[] @relation("VehicleAssignedDriver")

  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  DriverLocation DriverLocation[]

  @@map("drivers")
}

model DriverDocument {
  id Int @id @default(autoincrement())

  driver_id Int
  driver    Driver @relation(fields: [driver_id], references: [id], onDelete: Cascade)

  document_type DriverDocumentType

  file_path String
  file_name String?

  is_active   Boolean   @default(true)
  expiry_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([driver_id])
  @@map("driver_documents")
}

model DriverRate {
  id Int @id @default(autoincrement())

  driver_id Int
  driver    Driver @relation(fields: [driver_id], references: [id], onDelete: Cascade)

  hourly_rate         Float?
  hourly_rate_weekend Float?

  night_rate         Float?
  night_rate_weekend Float?

  created_at DateTime @default(now())

  @@index([driver_id])
  @@map("driver_rates")
}

model DriverLocation {
  id Int @id @default(autoincrement())

  driver_id Int
  driver    Driver @relation(fields: [driver_id], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float

  recorded_at DateTime @default(now())

  @@index([driver_id])
  @@map("driver_locations")
}

// ─── Job ────

enum JobStatus {
  scheduled
  inProgress
  completed
  cancelled

  @@map("job_status")
}

enum JobAssignmentStatus {
  assigned
  inProgress
  completed
  cancelled

  @@map("job_assignment_status")
}

enum JobPriority {
  high
  normal
  low
  urgent

  @@map("job_priority")
}

enum QuantityUnit {
  tonnes
  load

  @@map("quantity_unit")
}

model Job {
  id              Int      @id @default(autoincrement())
  job_number      String   @unique

  client_id       Int
  client          Client   @relation(fields: [client_id], references: [id])

  contract_id     Int?
  contract        ClientContract? @relation("JobContract", fields: [contract_id], references: [id])
  assignments     JobAssignment[]

  tip_id          Int?
  tip             ClientContract? @relation("JobTip", fields: [tip_id], references: [id])
  tip_address     String?
  tip_rate        Float?
  tip_billing_type BillingType?

  pick_up_address String
  entry_date      DateTime
  delivery_date   DateTime
  material        String
  quantity        Float
  quantity_unit   QuantityUnit
  rate            Float
  billing_type    BillingType
  toll_handling   TollHandling @default(included)
  one_way_toll    Float?
  return_toll     Float?
  notes           String?

  priority        JobPriority
  status          JobStatus @default(scheduled)

  created_by      Int?
  creator         User? @relation("JobCreator", fields: [created_by], references: [id], onDelete: SetNull)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([client_id])
  @@map("jobs")
}

model JobAssignment {
  id         Int @id @default(autoincrement())

  job_id     Int
  job        Job @relation(fields: [job_id], references: [id])

  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id])

  driver_id  Int
  driver     Driver @relation(fields: [driver_id], references: [id])

  status     JobAssignmentStatus @default(assigned)

  created_at DateTime @default(now())

  @@unique([job_id, vehicle_id]) // prevent duplicate vehicle per job
  @@index([vehicle_id])
  @@index([driver_id])
}