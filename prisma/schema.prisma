generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String?
  email         String   @unique
  password_hash String
  roles         Role[]
  status        Int      @default(1) // 0: inactive, 1: active
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  invite_token  String?
  audit_logs    AuditLog[]

  @@map("users")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actor_id    Int?
  actor       User?    @relation(fields: [actor_id], references: [id])
  action      String   // CREATE, UPDATE, DELETE, INVITE_SENT, LOGIN, etc.
  entity_type String   // User, Job, Invoice, Vehicle, etc.
  entity_id   Int?     // ID of the entity affected
  metadata    Json?    // Optional JSON data for extra details
  created_at  DateTime @default(now())

  @@map("audit_logs")
}
