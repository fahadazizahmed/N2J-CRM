generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Role {
    id          Int      @id @default(autoincrement())
    name        UserRole @unique
    permissions Json?
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("roles")
}

model User {
    id               Int            @id @default(autoincrement())
    name             String?
    email            String
    password         String
    role             UserRole
    status           Int            @default(1)
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt
    auditLogs        AuditLog[]
    client           Client?
    compliance       Compliance[]
    driver           Driver?
    receivedMessages Message[]      @relation("ReceivedMessages")
    sentMessages     Message[]      @relation("SentMessages")
    subcontractor    Subcontractor?
    sessions         UserSession[]

    @@unique([email, role], name: "email_role_unique")
    @@index([email])
    @@map("users")
}

model UserSession {
    id           Int       @id @default(autoincrement())
    userId       Int
    sessionToken String    @unique
    ipAddress    String?
    loginAt      DateTime  @default(now())
    logoutAt     DateTime?
    status       Int       @default(1) // 1 = Active, 0 = Inactive
    user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([status])
    @@map("user_sessions")
}

model Client {
    id          Int        @id @default(autoincrement())
    userId      Int        @unique
    companyName String
    contactName String
    email       String
    phone       String
    address     String?
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    contracts   Contract[] @relation("ClientContracts")
    invoices    Invoice[]
    jobs        Job[]

    @@map("clients")
}

model Subcontractor {
    id          Int        @id @default(autoincrement())
    userId      Int        @unique
    companyName String
    contactName String
    email       String
    phone       String
    address     String?
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
    contracts   Contract[] @relation("SubcontractorContracts")
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("subcontractors")
}

model Driver {
    id                 Int                    @id @default(autoincrement())
    userId             Int                    @unique
    firstName          String
    lastName           String
    status             DriverStatus           @default(ACTIVE)
    type               DriverType             @default(IN_HOUSE)
    licenseNumber      String
    insuranceDetails   String?
    whiteCard          String?
    currentLatitude    Float?
    currentLongitude   Float?
    lastLocationUpdate DateTime?
    currentVehicleId   Int?
    mileage            Float                  @default(0)
    createdAt          DateTime               @default(now())
    updatedAt          DateTime               @updatedAt
    checklists         DriverChecklist[]
    historicalVehicles DriverVehicleHistory[]
    currentVehicle     Vehicle?               @relation("CurrentDrivers", fields: [currentVehicleId], references: [id])
    user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    jobs               Job[]

    @@index([userId])
    @@index([currentVehicleId])
    @@map("drivers")
}

model Vehicle {
    id                 Int                    @id @default(autoincrement())
    registrationNumber String                 @unique
    type               VehicleType
    status             VehicleStatus          @default(ACTIVE)
    loadRate           Float?
    mileage            Float                  @default(0)
    lastServiceDate    DateTime?
    configuration      Json?
    createdAt          DateTime               @default(now())
    updatedAt          DateTime               @updatedAt
    historicalDrivers  DriverVehicleHistory[]
    currentDrivers     Driver[]               @relation("CurrentDrivers")
    jobs               Job[]

    @@map("vehicles")
}

model DriverVehicleHistory {
    id           Int       @id @default(autoincrement())
    driverId     Int
    vehicleId    Int
    assignedAt   DateTime  @default(now())
    unassignedAt DateTime?
    driver       Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
    vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    @@unique([driverId, vehicleId, assignedAt])
    @@index([driverId])
    @@index([vehicleId])
    @@map("driver_vehicle_history")
}

model Job {
    id             Int           @id @default(autoincrement())
    clientId       Int
    driverId       Int?
    vehicleId      Int?
    status         JobStatus     @default(SCHEDULED)
    priority       JobPriority   @default(NORMAL)
    scheduledStart DateTime
    scheduledEnd   DateTime
    actualHours    Float?
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt
    invoices       Invoice[]
    delivery       JobDelivery?
    materials      JobMaterial[]
    client         Client        @relation(fields: [clientId], references: [id])
    driver         Driver?       @relation(fields: [driverId], references: [id])
    vehicle        Vehicle?      @relation(fields: [vehicleId], references: [id])
    messages       Message[]

    @@index([clientId])
    @@index([driverId])
    @@index([vehicleId])
    @@index([status])
    @@map("jobs")
}

model JobMaterial {
    id           Int       @id @default(autoincrement())
    jobId        Int
    materialName String
    sku          String?
    description  String?
    qty          Float
    weight       Float?
    unitPrice    Float
    supplierId   Int?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
    job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
    supplier     Supplier? @relation(fields: [supplierId], references: [id])

    @@index([jobId])
    @@index([supplierId])
    @@map("job_materials")
}

model Supplier {
    id        Int           @id @default(autoincrement())
    name      String
    email     String?
    phone     String?
    address   String?
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
    materials JobMaterial[]

    @@map("suppliers")
}

model JobDelivery {
    id            Int      @id @default(autoincrement())
    jobId         Int      @unique
    deliveredAt   DateTime
    signaturePath String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

    @@map("job_deliveries")
}

model Invoice {
    id            Int              @id @default(autoincrement())
    jobId         Int
    clientId      Int
    amount        Float
    status        InvoiceStatus    @default(PENDING)
    issueDate     DateTime         @default(now())
    dueDate       DateTime
    paymentMethod String?
    createdAt     DateTime         @default(now())
    updatedAt     DateTime         @updatedAt
    payments      InvoicePayment[]
    client        Client           @relation(fields: [clientId], references: [id])
    job           Job              @relation(fields: [jobId], references: [id])

    @@index([jobId])
    @@index([clientId])
    @@index([status])
    @@map("invoices")
}

model InvoicePayment {
    id            Int      @id @default(autoincrement())
    invoiceId     Int
    amountPaid    Float
    paymentDate   DateTime @default(now())
    paymentMethod String
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

    @@index([invoiceId])
    @@map("invoice_payments")
}

model Contract {
    id               Int            @id @default(autoincrement())
    clientId         Int?
    subcontractorId  Int?
    title            String
    description      String?
    startDate        DateTime
    endDate          DateTime?
    termsConditions  String?
    swmsDocumentPath String?
    whsPoliciesPath  String?
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt
    client           Client?        @relation("ClientContracts", fields: [clientId], references: [id])
    subcontractor    Subcontractor? @relation("SubcontractorContracts", fields: [subcontractorId], references: [id])

    @@index([clientId])
    @@index([subcontractorId])
    @@map("contracts")
}

model Compliance {
    id           Int              @id @default(autoincrement())
    title        String
    category     String
    assignedTo   Int
    status       ComplianceStatus @default(PENDING)
    dueDate      DateTime?
    expiryDate   DateTime?
    documentPath String?
    createdAt    DateTime         @default(now())
    updatedAt    DateTime         @updatedAt
    user         User             @relation(fields: [assignedTo], references: [id])

    @@index([assignedTo])
    @@index([status])
    @@map("compliance")
}

model DriverChecklist {
    id            Int             @id @default(autoincrement())
    driverId      Int
    jobId         Int?
    checklistType ChecklistType
    status        ChecklistStatus @default(PENDING)
    completedAt   DateTime?
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    driver        Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)

    @@index([driverId])
    @@index([jobId])
    @@map("driver_checklists")
}

model Message {
    id          Int       @id @default(autoincrement())
    senderId    Int
    receiverId  Int
    jobId       Int?
    messageText String
    readAt      DateTime?
    createdAt   DateTime  @default(now())
    job         Job?      @relation(fields: [jobId], references: [id])
    receiver    User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
    sender      User      @relation("SentMessages", fields: [senderId], references: [id])

    @@index([senderId])
    @@index([receiverId])
    @@index([jobId])
    @@map("messages")
}

model AuditLog {
    id         Int      @id @default(autoincrement())
    userId     Int
    action     String
    entityType String
    entityId   Int?
    timestamp  DateTime @default(now())
    user       User     @relation(fields: [userId], references: [id])

    @@index([userId])
    @@index([entityType, entityId])
    @@map("audit_logs")
}

model SystemSetting {
    id          Int      @id @default(autoincrement())
    key         String   @unique
    value       String
    description String?
    updatedAt   DateTime @updatedAt

    @@map("system_settings")
}

model Integration {
    id          Int      @id @default(autoincrement())
    serviceName String
    apiKey      String?
    webhookUrl  String?
    status      Int      @default(1)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("integrations")
}

model SystemHealth {
    id            Int                @id @default(autoincrement())
    serviceName   String
    status        SystemHealthStatus @default(OK)
    lastChecked   DateTime           @default(now())
    uptimePercent Float?

    @@map("system_health")
}

enum UserRole {
    ADMIN
    MANAGER
    DRIVER
    CLIENT
    SUBCONTRACTOR
}

enum DriverStatus {
    ACTIVE
    MAINTENANCE
    IDLE
    OUT_OF_SERVICE
}

enum DriverType {
    IN_HOUSE
    SUBCONTRACTOR
}

enum VehicleType {
    TIPPER
    FLATBED
    TANKER
    OTHER
}

enum VehicleStatus {
    ACTIVE
    MAINTENANCE
    IDLE
    OUT_OF_SERVICE
}

enum JobStatus {
    SCHEDULED
    IN_PROGRESS
    COMPLETED
    CANCELLED
}

enum JobPriority {
    HIGH
    NORMAL
    LOW
}

enum InvoiceStatus {
    PAID
    PENDING
    OVERDUE
}

enum ChecklistType {
    PRE_START
    POST_COMPLETION
    DUTY_OF_CARE
    COMPLIANCE
}

enum ChecklistStatus {
    PENDING
    COMPLETED
}

enum ComplianceStatus {
    PENDING
    COMPLETED
    OVERDUE
}

enum SystemHealthStatus {
    OK
    WARNING
    DOWN
}
